# Copy this to .env on the Synology NAS at /volume1/docker/mithrandir/.env
# Then docker compose up -d --build will pick it up automatically.

# ─── Ollama ───────────────────────────────────────────────────────────────────
# Your Mac's local IP address (find with: ipconfig getifaddr en0)
OLLAMA_BASE_URL=http://192.168.1.72:11434

# Chat model — must already be pulled on the Mac (ollama pull deepseek-r1:14b)
CHAT_MODEL=deepseek-r1:14b

# Embedding model — must already be pulled on the Mac (ollama pull mxbai-embed-large)
EMBEDDING_MODEL=mxbai-embed-large
